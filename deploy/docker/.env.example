# PostgreSQL
POSTGRES_USER=releaselab
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_CONNECTION=Host=postgres;Database=releaselab;Username=releaselab;Password=change-me-in-production

# Redis
REDIS_CONNECTION=redis:6379

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-in-production

# JWT
JWT_SECRET=generate-a-64-char-random-string-for-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend
FRONTEND_URL=https://yourdomain.com
